platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

use_modular_headers!

target 'Runner' do
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    if target.name == 'gRPC-Core'
      target.build_configurations.each do |config|
        config.build_settings['MODULEMAP_FILE'] = 'Target Support Files/gRPC-Core/gRPC-Core.modulemap'
      end
    end
  end

  Dir.glob(File.join(__dir__, 'Pods', 'Target Support Files', '**', '*.xcconfig')).each do |xcconfig|
    contents = File.read(xcconfig)
    updated_contents = contents.gsub(
      'Headers/Private/grpc/gRPC-Core.modulemap',
      'Target Support Files/gRPC-Core/gRPC-Core.modulemap'
    ).gsub(
      '-weak_framework "FirebaseFirestoreInternal"',
      ''
    )

    next if updated_contents == contents

    File.write(
      xcconfig,
      updated_contents
    )
  end

  Dir.glob(File.join(__dir__, 'Pods', 'Target Support Files', '**', '*-frameworks.sh')).each do |frameworks_script|
    contents = File.read(frameworks_script)
    next unless contents.include?('local destination="${TARGET_BUILD_DIR}/${FRAMEWORKS_FOLDER_PATH}"')

    updated_contents = contents.gsub(
      <<~'BEFORE',
  elif [ -r "$1" ]; then
    local source="$1"
  fi

  local destination="${TARGET_BUILD_DIR}/${FRAMEWORKS_FOLDER_PATH}"
BEFORE
      <<~'AFTER'
  elif [ -r "$1" ]; then
    local source="$1"
  else
    echo "warning: Framework $1 was not built; skipping embed step."
    return
  fi

  local destination="${TARGET_BUILD_DIR}/${FRAMEWORKS_FOLDER_PATH}"
AFTER
    )

    next if updated_contents == contents

    File.write(frameworks_script, updated_contents)
  end
end
